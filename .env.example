# Stock Oracle — Environment Configuration
# ==========================================
# Copy this file to .env and fill in your API keys.
# Place the .env file in the stock_oracle/ directory (next to config.py).
#
# All keys are optional — the app works without them but with reduced
# data coverage. More keys = more data = better predictions.

# ── Essential (Recommended) ──────────────────────────────────
# Finnhub: FREE at https://finnhub.io/register
# Gives real-time stock prices and company news.
FINNHUB_API_KEY=your_finnhub_key_here

# Anthropic: https://console.anthropic.com
# Enables Claude AI advisor during monitoring (~$5/month with Haiku).
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MONTHLY_CAP=10

# ── Free Data APIs (Optional) ────────────────────────────────
# SEC EDGAR: just needs your email (required format shown below)
SEC_USER_AGENT=StockOracle your@email.com

# FRED: FREE at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# News API: FREE at https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Reddit: FREE at https://www.reddit.com/prefs/apps (create a "script" app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_secret

# GitHub: FREE at https://github.com/settings/tokens (avoids rate limits)
GITHUB_TOKEN=your_github_token_here

# ── Broker APIs (Optional) ───────────────────────────────────
# Alpaca: FREE paper trading at https://alpaca.markets
ALPACA_KEY_ID=
ALPACA_SECRET=

# ── Local AI (Optional) ──────────────────────────────────────
# Ollama: https://ollama.ai — runs LLMs locally for NLP analysis
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# ── Settings ─────────────────────────────────────────────────
MONITOR_INTERVAL=300
PREDICTION_HORIZON_DAYS=5
BACKTEST_STOP_LOSS=0.05
BACKTEST_TAKE_PROFIT=0.15
